# ── Core backend ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://adhd:adhd_secret@localhost:5432/adhd_dashboard
SECRET_KEY=your_super_secret_jwt_key_change_this
CORS_ORIGINS=["http://localhost:5173"]

# ── AI provider — set ONE of the three blocks below ───────────────────────────
# Priority when multiple keys are set: Z.ai > NVIDIA > OpenAI

# Option A: OpenAI (paid — https://platform.openai.com)
OPENAI_API_KEY=sk-...

# Option B: NVIDIA NIM (free — https://build.nvidia.com)
NVIDIA_API_KEY=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
NVIDIA_MODEL=meta/llama-3.1-8b-instruct
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Option C: Z.ai / ZhipuAI GLM (free — https://open.bigmodel.cn)
# 1. Sign up at https://open.bigmodel.cn
# 2. Go to API Keys and create one
ZAI_API_KEY=your_zai_api_key
ZAI_MODEL=glm-5.1
ZAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# ── Redis (auto-configured via Docker Compose) ────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Supabase — real-time presence (optional, free tier at supabase.com) ───────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Notion — progress export (optional, free at notion.so) ───────────────────
NOTION_TOKEN=secret_...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Frontend (prefix with VITE_) ─────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
