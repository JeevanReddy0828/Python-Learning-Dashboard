# ── Core backend ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://adhd:adhd_secret@localhost:5432/adhd_dashboard
SECRET_KEY=your_super_secret_jwt_key_change_this
OPENAI_API_KEY=sk-...
CORS_ORIGINS=["http://localhost:5173"]

# ── Redis (auto-configured via Docker Compose) ────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Supabase — real-time presence (optional, free tier at supabase.com) ───────
# 1. Create a project at https://supabase.com
# 2. Settings → API → copy Project URL and anon/public key
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Notion — progress export (optional, free at notion.so) ───────────────────
# 1. Go to https://www.notion.so/my-integrations → New integration
# 2. Create a database in Notion, share it with your integration
# 3. Copy the integration secret (starts with secret_) and database ID
NOTION_TOKEN=secret_...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Frontend (prefix with VITE_) ─────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
