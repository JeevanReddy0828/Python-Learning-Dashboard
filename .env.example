# ── Core backend ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://adhd:adhd_secret@localhost:5432/adhd_dashboard
SECRET_KEY=your_super_secret_jwt_key_change_this
CORS_ORIGINS=["http://localhost:5173"]

# ── AI provider — set ONE of the two blocks below ─────────────────────────────

# Option A: OpenAI (paid)
OPENAI_API_KEY=sk-...

# Option B: NVIDIA NIM (free tier at https://build.nvidia.com/)
# When NVIDIA_API_KEY is set it takes priority over OPENAI_API_KEY.
# Pick any model from https://build.nvidia.com/explore/discover
NVIDIA_API_KEY=nvapi-...
NVIDIA_MODEL=meta/llama-3.1-8b-instruct
# NVIDIA_MODEL=nvidia/llama-3.1-nemotron-70b-instruct
# NVIDIA_MODEL=mistralai/mistral-7b-instruct-v0.3
# NVIDIA_MODEL=microsoft/phi-3-mini-128k-instruct
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# ── Redis (auto-configured via Docker Compose) ────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Supabase — real-time presence (optional, free tier at supabase.com) ───────
# 1. Create a project at https://supabase.com
# 2. Settings → API → copy Project URL and anon/public key
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Notion — progress export (optional, free at notion.so) ───────────────────
# 1. Go to https://www.notion.so/my-integrations → New integration
# 2. Create a database in Notion, share it with your integration
# 3. Copy the integration secret (starts with secret_) and database ID
NOTION_TOKEN=secret_...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Frontend (prefix with VITE_) ─────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
